# ==============================================================================
# Flow Delinquency Agent — Environment Variables
# Copy this file to .env and fill in values.
# SANDBOX=true is the default. Never set SANDBOX=false without explicit sign-off.
# ==============================================================================

# --- Sandbox Safety -----------------------------------------------------------
# MUST be explicitly set to false for production — agent defaults to true
SANDBOX=true

# --- Agent Config -------------------------------------------------------------
DELINQUENCY_THRESHOLD_DAYS=5
DELINQUENCY_PROPERTY_ID=brickell
DELINQUENCY_SCHEDULE_CRON=0 8 * * *
AGENT_ID=delinquency-agent-v1

# --- Supabase -----------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# --- Snowflake (read-only service account) ------------------------------------
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=ANALYTICS
SNOWFLAKE_SCHEMA=FINANCIAL
SNOWFLAKE_WAREHOUSE=

# --- Slack --------------------------------------------------------------------
# Webhook URL for property manager escalation channel
PM_SLACK_CHANNEL=#property-brickell
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# --- Dashboard ----------------------------------------------------------------
DASHBOARD_BASE_URL=https://app.flow.life

# --- Twilio (production only — leave blank in sandbox) -----------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Property Info ------------------------------------------------------------
PROPERTY_NAME=Flow Brickell
PROPERTY_PHONE=(305) 555-0100
PAYMENT_URL=https://pay.flow.life/brickell
